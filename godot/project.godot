; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Periliminal"
config/description="Cat-themed social casino MMO"
config/version="0.1.0"
config/tags=PackedStringArray("mmo", "casino", "social", "cats")
run/main_scene="res://scenes/ui/splash.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/ui/icon.png"

[autoload]

AutoloadInit="*res://src/core/autoload_init.gd"
ExternalHandoff="*res://src/core/external_handoff.gd"
WorldLoader="*res://src/world/world_loader.gd"
