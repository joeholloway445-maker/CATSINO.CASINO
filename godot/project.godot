DiscoveryManager="*res://src/world/discovery_manager.gd"
DiscordTicketClient="*res://src/networking/discord_ticket_client.gd"
GameData="*res://hdv_lore/src/core/game_data.gd"
WorldRegistry="*res://hdv_lore/src/core/world_registry.gd"
PersonaMatrixClient="*res://hdv_lore/src/networking/persona_matrix_client.gd"
