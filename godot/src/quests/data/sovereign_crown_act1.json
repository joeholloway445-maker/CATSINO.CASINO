            },
            "rewards": {
              "xp": 250,
              "currency": 100,
              "faction_rep": {"SovereignCrown": -50},
              "npc_disposition": {
                "auditor_crown": -75,
                "banker_supraliminal": 150
              }
            }
          }
        }
      }
    ]
  },
  {
