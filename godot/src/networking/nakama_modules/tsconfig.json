{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "lib": ["es2017"],
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "build"
  },
  "include": ["./*.ts", "./nakama-runtime.d.ts", "../../../world_data/shops.json"],
  "exclude": ["node_modules", "build"]
}
