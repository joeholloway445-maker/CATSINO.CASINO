static func by_faction(faction: String) -> Array[Dictionary]:
	if faction == "Factionless":
		return FACTIONLESS_LINES.duplicate()
	var result: Array[Dictionary] = []
	for l in LINES:
		if l.faction == faction:
			result.append(l)
	return result

static func random_line(faction: String) -> Dictionary:
	var pool := by_faction(faction)
	if pool.is_empty():
		return {}
	return pool[randi() % pool.size()]

## Picks the strongest stage that exists for a line, at or below `max_stage`.
static func stage_for(line: Dictionary, max_stage: int) -> Dictionary:
	var stages: Array = line.get("stages", [])
	for s in range(mini(max_stage, stages.size()) - 1, -1, -1):
		if not stages[s].is_empty():
			return stages[s]
	return {}
